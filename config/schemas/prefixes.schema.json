{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Country prefixes artifact",
  "description": "All IPv4 prefixes allocated to a country from RIR delegated stats, enriched with BGP observation status.",
  "type": "object",
  "required": ["country_code", "generated_ts", "source", "prefixes"],
  "properties": {
    "country_code": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "generated_ts": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "description": "e.g. lacnic-delegated-extended" },
    "source_serial": { "type": "string" },
    "total_prefixes": { "type": "integer" },
    "total_addresses": { "type": "integer" },
    "prefixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prefix", "prefix_start", "prefix_end", "prefix_length", "address_count", "origin_asns", "observed_in_bgp", "confidence"],
        "properties": {
          "prefix": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+\\.\\d+/\\d{1,2}$" },
          "prefix_start": { "type": "integer", "description": "IPv4 as uint32" },
          "prefix_end": { "type": "integer", "description": "IPv4 as uint32" },
          "prefix_length": { "type": "integer", "minimum": 8, "maximum": 32 },
          "address_count": { "type": "integer" },
          "origin_asns": { "type": "array", "items": { "type": "integer" } },
          "origin_names": { "type": "array", "items": { "type": "string" } },
          "observed_in_bgp": { "type": "boolean" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "rir_status": { "type": "string" }
        }
      }
    }
  }
}
